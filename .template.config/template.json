{
  "$schema": "http://json.schemastore.org/template",
  "author": "Diihveloper",
  "classifications": [
    "Common",
    "Api"
  ],
  "sources": [
    {
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        ".template.config/**/*",
        "**/*.filelist",
        "**/*.user",
        "**/*.lock.json",
        ".gitattributes",
        ".gitignore",
        ".git/**/*",
        ".vscode/**/*",
        ".idea/**/*",
        "README.md"
      ],
      "modifiers": [
        {
          "condition": "(!SMTP)",
          "exclude": [
            "src/DiihTemplate.Infra/Email/**",
            "src/DiihTemplate.Core/Services/IEmailSender.cs"
          ]
        },
        {
          "condition": "(!RABBITMQ)",
          "exclude": [
            "src/DiihTemplate.Infra/Messaging/**",
            "src/DiihTemplate.Core/Services/IMessageBroker.cs"
          ]
        },
        {
          "condition": "(!STORAGE)",
          "exclude": [
            "src/DiihTemplate.Infra/Storage/**",
            "src/DiihTemplate.Core/Services/IFileStorage.cs"
          ]
        }
      ]
    }
  ],
  "specialCustomOperations": {
    "**/*.md": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": ["<!--#if"],
            "else": ["<!--#else"],
            "elseif": ["<!--#elseif"],
            "endif": ["<!--#endif"],
            "trim": true,
            "wholeLine": true
          }
        }
      ]
    }
  },
  "symbols": {
    "DATABASE": {
      "type": "parameter",
      "description": "Banco de dados usado",
      "datatype": "choice",
      "enableQuotelessLiterals": true,
      "choices": [
        {
          "choice": "Postgres",
          "description": "Postegres database"
        },
        {
          "choice": "SqlServer",
          "description": "SqlServer database"
        }
      ],
      "defaultValue": "Postgres"
    },
    "POSTGRES": {
      "type": "computed",
      "value": "DATABASE == Postgres"
    },
    "SQLSERVER": {
      "type": "computed",
      "value": "DATABASE == SqlServer"
    },
    "SMTP": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Incluir suporte a envio de emails via SMTP (MailKit)",
      "defaultValue": "false"
    },
    "RABBITMQ": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Incluir suporte a mensageria com RabbitMQ",
      "defaultValue": "false"
    },
    "STORAGE": {
      "type": "parameter",
      "datatype": "bool",
      "description": "Incluir suporte a armazenamento de arquivos (local)",
      "defaultValue": "false"
    }
  },
  "identity": "DiihVeloper.Template",
  "name": "Template base para projetos",
  "shortName": "diihtemplate",
  "sourceName": "DiihTemplate",
  "tags": {
    "language": "C#",
    "type": "project"
  }
}